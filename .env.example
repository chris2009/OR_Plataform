# ============================================================
# YOLO Surveillance Platform — Variables de Entorno
# Copiar a .env y ajustar valores antes de levantar Docker
# ============================================================

# --- PostgreSQL ---
POSTGRES_USER=vigilancia
POSTGRES_PASSWORD=secure_pass
POSTGRES_DB=yolo_platform

# --- JWT Auth ---
# Generar con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=super_secret_jwt_key_change_me_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# --- Redis ---
REDIS_URL=redis://redis:6379

# --- CORS (separar múltiples orígenes con comas) ---
BACKEND_CORS_ORIGINS=http://localhost,http://localhost:3000,http://localhost:80

# --- Fernet (cifrado de contraseñas de cámaras) ---
# Generar con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=generate_a_real_fernet_key_here

# --- Frontend (usadas en build time por Vite) ---
VITE_API_URL=http://localhost/api
VITE_WS_URL=ws://localhost/ws
